#!/bin/bash

XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-~/.config}

# Allow users to override command-line options
if [[ -f $XDG_CONFIG_HOME/cast-codes@@CHANNEL_SUFFIX@@-flags.conf ]]; then
    CAST_CODES_USER_FLAGS="$(grep -v '^#' $XDG_CONFIG_HOME/cast-codes@@CHANNEL_SUFFIX@@-flags.conf)"
fi

# Launch
exec /opt/castcodes/cast-codes@@CHANNEL_SUFFIX@@/@@BINARY_NAME@@ $CAST_CODES_USER_FLAGS "$@"
