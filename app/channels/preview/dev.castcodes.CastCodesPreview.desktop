[Desktop Entry]
# The version of the desktop entry spec this conforms to.
Version=1.0

Type=Application

Name=CastCodesPreview
GenericName=TerminalEmulator

Exec=cast-codes-preview %U
StartupWMClass=dev.castcodes.CastCodesPreview

Keywords=shell;prompt;command;commandline;cmd;

Icon=dev.castcodes.CastCodesPreview

Categories=System;TerminalEmulator;

# Don't run this application within a terminal.
Terminal=false

# Register ourselves as the handler for castcodespreview:// URLs.
MimeType=x-scheme-handler/castcodespreview;
