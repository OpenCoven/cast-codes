[Desktop Entry]
# The version of the desktop entry spec this conforms to.
Version=1.0

Type=Application

Name=CastCodesLocal
GenericName=TerminalEmulator

Exec=cast-codes-local %U
StartupWMClass=dev.castcodes.CastCodesLocal

Keywords=shell;prompt;command;commandline;cmd;

Icon=dev.castcodes.CastCodesLocal

Categories=System;TerminalEmulator;

# Don't run this application within a terminal.
Terminal=false

# Register ourselves as the handler for castcodeslocal:// URLs.
MimeType=x-scheme-handler/castcodeslocal;
